# PokéWallet API (required for card matching)
POKEWALLET_API_KEY=

# Database (Railway Postgres injects DATABASE_URL as postgresql://; the app converts to +asyncpg)
DATABASE_URL=

# Auth (REQUIRED in prod — app refuses to start without it, and rejects secrets < 32 bytes).
# Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
AUTH_SECRET=

# Pull photo storage (Railway Volume mount path in prod; local dir in dev)
PHOTO_STORAGE_DIR=/data

# Cookies: true in prod (HTTPS), false for local http dev
COOKIE_SECURE=true

# Pack pipeline tuning (defaults shown; T from scripts/sweep_threshold.py)
PACK_CONFIDENCE_THRESHOLD=0.80
PACK_MIN_ROWS=5
PACK_MAX_ROWS=13
PACK_GUIDE_SNAP_TOL=0.35
PACK_STRIP_BAND_FRAC=0.85

# Stats batch (sub-project C)
STATS_CRON_TOKEN=
PACK_STATS_MIN_SAMPLE=30
PACK_STATS_Z_THRESHOLD=3.0
PACK_STATS_CONCENTRATION=0.5
PACK_STATS_PRIOR_STRENGTH=20
PRICE_SNAPSHOT_INTERVAL_DAYS=7
PRICE_JUMP_THRESHOLD=0.5
PRICE_LOOKUP_DELAY_MS=200

CORS_ORIGINS=*
LOG_LEVEL=INFO

# --- Visual matcher (sub-project H) ---
# Main app: URL of the matcher service; UNSET disables art matching entirely.
# Railway: second service from this repo (Dockerfile matcher/Dockerfile, root "/"),
# Volume mounted at /data, private networking → http://<service>.railway.internal:8080
MATCHER_URL=
MATCHER_TOKEN=change-me-shared-bearer-token
# Fusion thresholds (cosine): accept art match at/above ACCEPT with top1-top2 margin
PACK_MATCH_ACCEPT=0.85
PACK_MATCH_MARGIN=0.02

# Tests/dev only: point at the local PokéWallet stub
# POKEWALLET_BASE_URL=http://127.0.0.1:8901

# --- Railway stats cron (USER ACTION, configured in Railway, not here) ---
# Add a second Railway service ("stats-cron") in the same project, sharing env, that runs
# on a schedule (e.g. cron "0 7 * * *") with the command:
#   sh -c 'curl -fsS -X POST "$WEB_ORIGIN/admin/stats/recompute" -H "authorization: Bearer $STATS_CRON_TOKEN"'
# where WEB_ORIGIN is the deployed web service URL. The web service runs the batch
# (it has the photo Volume); the cron service only triggers it.

# --- Training data screens (sub-project I, phase 2) ---
# Where the synthetic-training datasets live for the admin Synthetic browser.
# Only meaningful on the training machine; leave unset on Railway.
TRAINING_DATA_DIR=./training/data

# --- Confidence-gated VLM fallback (sub-project K, phase 2) ---
# Cards the pipeline still flags needs_review are sent to a RunPod-hosted
# Qwen2.5-VL worker for definitive ID. UNSET = feature off (exact Phase-1
# behavior). Deploy runpod_worker/ as a RunPod Serverless endpoint, then:
VLM_ENDPOINT=            # https://api.runpod.ai/v2/<endpoint-id>
VLM_API_KEY=            # your RunPod API key
# VLM_MODEL is set on the worker (default Qwen/Qwen2.5-VL-7B-Instruct)

# --- OCR tuning (pack + live scan share these) ---
# Pins ONNX/cv2 thread counts (0 = library auto-detect). Set to the Railway
# plan's vCPU count, e.g. 2, to avoid oversubscription under concurrent scans.
OCR_THREADS=
# Shared OCR admission gate (asyncio.Semaphore) across pack scans and live-scan
# frames — bounds how many OCR passes run concurrently on one instance.
OCR_CONCURRENCY=3
