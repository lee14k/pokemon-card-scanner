{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22"
  },
  "steps": {
    "build": {
      "commands": [
        "...",
        "cd frontend && npm ci && npm run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --proxy-headers --forwarded-allow-ips='*'",
    "aptPackages": ["tesseract-ocr"]
  }
}
